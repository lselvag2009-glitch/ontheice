.quote-card{border-radius:16px;padding:16px 18px;margin-bottom:14px;position:relative;overflow:hidden;}
.mood-grid{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px;}
.mood-btn{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);border-radius:10px;padding:7px 10px;display:flex;align-items:center;gap:5px;color:#5A7A9A;font-size:12px;font-weight:600;}
.cpick{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:12px;}
.cpick .cc{width:28px;height:28px;border-radius:50%;cursor:pointer;border:3px solid transparent;}
.cpick .cc.active{border-color:#fff;}
.pom-circle{position:relative;display:inline-flex;align-items:center;justify-content:center;margin-bottom:14px;}
.pom-time{position:absolute;text-align:center;}
#toast-wrap{position:fixed;top:12px;left:16px;right:16px;z-index:9998;pointer-events:none;}
.toast{background:rgba(10,22,40,0.97);border-radius:12px;padding:11px 15px;margin-bottom:8px;border-left:4px solid var(--accent);animation:slideUp 0.3s ease;box-shadow:0 8px 32px rgba(0,0,0,0.8);}
.toast .tt{font-weight:700;font-size:13px;}
.toast .tb{font-size:12px;color:#6A8BAA;}
.section{animation:fadeIn 0.3s ease;}
.frow{display:flex;gap:8px;margin-bottom:10px;}
.frow input,.frow select{margin-bottom:0;}
.mb{margin-bottom:10px;}
.spinner{width:32px;height:32px;border:3px solid rgba(200,16,46,0.2);border-top-color:#C8102E;border-radius:50%;animation:spin 0.8s linear infinite;}
.center{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:70vh;gap:16px;}
</style>
</head>
