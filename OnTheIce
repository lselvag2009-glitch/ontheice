    <button onclick="showSection('more')" class="press" style="background:rgba(255,255,255,0.06);border:none;border-radius:10px;padding:7px 10px;color:#A8C8E8;font-size:14px;">←</button>
    <div class="stitle" style="margin-bottom:0;flex:1;"><div class="bar" style="background:#C8102E;"></div><span style="color:#C8102E;">❝ Citations</span></div>
    <span style="font-size:12px;color:var(--sub);">${QUOTES.length} · 💙 ${state.favs.length}</span>
  </div>
  <div class="pills" style="margin-bottom:14px;">
    ${[{k:"all",l:"Toutes"},{k:"S",l:"🍁 Shane"},{k:"I",l:"🐻 Ilya"},{k:"B",l:"🏒 Les deux"}].map(f=>`<div class="pill${fc===f.k?" active":""}" onclick="state.quotesFilter='${f.k}';render();" style="${fc===f.k?"background:rgba(200,16,46,0.2);border-color:rgba(200,16,46,0.4);color:#C8102E;":""}">${f.l}</div>`).join("")}
  </div>
  ${filtered.map(q=>{const ac=q.c==="S"?"#C8102E":q.c==="I"?"#0057A8":"#8B6A9A";const ri=QUOTES.indexOf(q);const isFav=state.favs.includes(ri);
