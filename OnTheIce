.card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:16px;margin-bottom:14px;animation:slideUp 0.25s ease;}
.btn{display:block;width:100%;padding:13px;border-radius:14px;font-weight:700;font-size:14px;text-align:center;color:#fff;background:linear-gradient(135deg,var(--accent),var(--accent2));box-shadow:0 4px 16px rgba(200,16,46,0.25);transition:transform 0.08s;}
.btn:active{transform:scale(0.96);}
.btn.b2{background:linear-gradient(135deg,#003580,#0057A8);box-shadow:0 4px 16px rgba(0,87,168,0.25);}
.btn.outline{background:transparent;border:1.5px solid rgba(200,16,46,0.5);color:var(--accent);box-shadow:none;}
.stitle{display:flex;align-items:center;gap:8px;margin-bottom:12px;}
