function getSmartQuote(text){
  if(!text||text.trim().length<10) return null;
  const lower = text.toLowerCase();
  const scores = new Array(QUOTES.length).fill(0);
  QUOTE_KEYWORDS.forEach(({words,indices})=>{
    if(words.some(w=>lower.includes(w))){
      indices.forEach(i=>{if(i<QUOTES.length)scores[i]+=1;});
    }
  });
  // Aussi boost selon le mood
  if(state.journalMood==="fire"||state.journalMood==="game") [0,2,4,6,7].forEach(i=>{if(i<QUOTES.length)scores[i]+=2;});
  if(state.journalMood==="love") [1,3,5,9,12,15].forEach(i=>{if(i<QUOTES.length)scores[i]+=2;});
  if(state.journalMood==="tired") [18,19,26,36].forEach(i=>{if(i<QUOTES.length)scores[i]+=2;});
  if(state.journalMood==="chill") [7,10,22,25].forEach(i=>{if(i<QUOTES.length)scores[i]+=2;});
  const maxScore = Math.max(...scores);
  if(maxScore===0) return QUOTES[Math.floor(Math.random()*QUOTES.length)];
  const best = scores.map((s,i)=>({s,i})).filter(x=>x.s===maxScore);
  const pick = best[Math.floor(Math.random()*best.length)];
  return {...QUOTES[pick.i], idx:pick.i};
}

// ── TOUTES LES CITATIONS ──────────────────────────────────────────────────────
