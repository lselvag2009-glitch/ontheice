@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
@keyframes splashOut{0%,70%{opacity:1}100%{opacity:0;pointer-events:none;display:none}}
.press:active{transform:scale(0.96);transition:transform 0.08s;}
#splash{position:fixed;inset:0;z-index:9999;background:#07080F;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;animation:splashOut 0.4s ease 2.2s forwards;}
.s-title{font-family:'Bebas Neue',Impact,sans-serif;font-size:38px;letter-spacing:5px;background:linear-gradient(135deg,#E8C4B8,#C8102E 40%,#0057A8 70%,#A8C8E8);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.s-sub{font-size:10px;letter-spacing:4px;color:#2A4060;text-transform:uppercase;}
.s-bar{width:140px;height:3px;background:rgba(255,255,255,0.08);border-radius:2px;overflow:hidden;}
@keyframes fill{from{width:0}to{width:100%}}
.s-fill{height:100%;background:linear-gradient(90deg,#C8102E,#0057A8);animation:fill 2s ease forwards;}
#topbar{background:rgba(7,8,15,0.95);border-bottom:1px solid rgba(200,16,46,0.15);padding:10px 16px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;padding-top:max(10px,env(safe-area-inset-top,10px));}
.logo{font-family:'Bebas Neue',Impact,sans-serif;font-size:20px;letter-spacing:3px;background:linear-gradient(135deg,#E8C4B8,var(--accent) 45%,var(--accent2) 75%,#A8C8E8);-webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1;}
.logo-sub{font-size:8px;letter-spacing:3px;color:#2A4060;text-transform:uppercase;}
#scroll{flex:1;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch;}
#content{padding:14px;max-width:500px;margin:0 auto;padding-bottom:24px;}
#nav{display:flex;background:rgba(6,10,20,0.97);border-top:1px solid rgba(200,16,46,0.2);padding-bottom:env(safe-area-inset-bottom,8px);flex-shrink:0;}
#nav button{flex:1;padding:10px 0 6px;background:none;display:flex;flex-direction:column;align-items:center;gap:3px;color:#3A5A7A;border:none;font-size:9px;font-weight:700;letter-spacing:0.5px;text-transform:uppercase;transition:color 0.2s;}
#nav button.active{color:var(--accent);}
#nav button .ni{font-size:19px;}
