function render(){
  document.getElementById("today-label").textContent=new Date().toLocaleDateString("fr-FR",{weekday:"short",day:"numeric",month:"short"}).toUpperCase();
  document.getElementById("score-label").textContent=new Date().toLocaleDateString("fr-FR",{day:"numeric",month:"long",year:"numeric"});
  document.querySelectorAll("#nav button").forEach(b=>b.classList.remove("active"));
  const nb=document.getElementById(`nav-${state.view}`);if(nb)nb.classList.add("active");
  document.getElementById("nav").style.display=state.view==="settings"?"none":"flex";
  document.getElementById("content").innerHTML=renderSection();
  document.getElementById("scroll").scrollTop=0;

  // Pomodoro timer
  if(state.pom.running&&!window._pt){
    window._pt=setInterval(()=>{
      state.pom.secs--;
      if(state.pom.secs<=0){
        clearInterval(window._pt);window._pt=null;state.pom.running=false;
        playSound("buzz");vib([200,100,200]);
        if(state.pom.mode==="work"){state.pom.sessions++;state.pom.mode="break";state.pom.secs=5*60;}
        else{state.pom.mode="work";state.pom.secs=25*60;}
        render();return;
      }
      const mm=String(Math.floor(state.pom.secs/60)).padStart(2,"0"),ss=String(state.pom.secs%60).padStart(2,"0");
      const pt=document.querySelector(".pom-time .pt");if(pt)pt.textContent=`${mm}:${ss}`;
      const arc=document.querySelector("#pom-arc");
      if(arc){const r=52,circ=2*Math.PI*r,base=state.pom.mode==="work"?25*60:5*60,pct=1-state.pom.secs/base;arc.style.strokeDashoffset=circ*(1-pct);}
    },1000);
  } else if(!state.pom.running&&window._pt){clearInterval(window._pt);window._pt=null;}
}

