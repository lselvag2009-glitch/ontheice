async function openActor(id){
  toast("👤","Chargement de l'acteur...","#FFD700");
  try{
    const [person, credits] = await Promise.all([
      tmdbFetch(`/person/${id}`),
      tmdbFetch(`/person/${id}/combined_credits`)
    ]);
    // Sort by popularity, keep movies + tv, remove duplicates
    const all = [...(credits.cast||[])];
    const seen = new Set();
    const filmography = all
      .filter(m=>{ const k=`${m.media_type}_${m.id}`; if(seen.has(k))return false; seen.add(k); return m.poster_path&&(m.title||m.name); })
      .sort((a,b)=>(b.popularity||0)-(a.popularity||0))
      .slice(0,24)
      .map(m=>({
        id:m.id, type:m.media_type,
        title:m.title||m.name,
        date:m.release_date||m.first_air_date||"",
        score:m.vote_average?m.vote_average.toFixed(1):"N/A",
        poster:m.poster_path?TMDB_IMG_SM+m.poster_path:null,
        char:m.character||""
      }));
    state.actorItem={
      id, name:person.name,
      photo:person.profile_path?TMDB_IMG_LG+person.profile_path:null,
      born:person.birthday||"",
      place:person.place_of_birth||"",
      bio:person.biography||"",
      known:person.known_for_department||"",
      filmography
    };
    showSection("actor");
  }catch(e){ toast("❌","Impossible de charger","#C8102E"); }
}

