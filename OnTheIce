    zone.innerHTML=`<div style="display:flex;align-items:center;justify-content:center;gap:10px;padding:30px;"><div class="spinner" style="width:22px;height:22px;border-width:2px;"></div><div style="font-size:13px;color:var(--sub);">Recherche...</div></div>`;
