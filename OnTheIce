const QUOTES=[
  {t:"«\u00a0Tu me détestes tellement que tu ne peux même pas me regarder.\u00a0»",a:"Shane Hollander",c:"S"},
  {t:"«\u00a0Sur la glace, on est ennemis. En dehors... je ne sais plus ce qu'on est.\u00a0»",a:"Ilya Rozanov",c:"I"},
  {t:"«\u00a0Chaque fois que je te vois, je me rappelle pourquoi je joue à ce sport.\u00a0»",a:"Shane Hollander",c:"S"},
  {t:"«\u00a0La rivalité s'arrête quand la sirène sonne. Ce qui vient après... c'est une autre histoire.\u00a0»",a:"Ilya Rozanov",c:"I"},
  {t:"«\u00a0Tu crois que je ne te vois pas ? Je ne vois que toi.\u00a0»",a:"Shane Hollander",c:"S"},
  {t:"«\u00a0On était faits pour être dans des camps opposés.\u00a0»",a:"Ilya Rozanov",c:"I"},
  {t:"«\u00a0Chaque cicatrice sur cette glace porte ton nom.\u00a0»",a:"Shane Hollander",c:"S"},
  {t:"«\u00a0La haine, c'est de l'amour qui porte un masque de hockey.\u00a0»",a:"— Rivalité Brûlante",c:"B"},
  {t:"«\u00a0Il n'y a rien de plus dangereux que quelqu'un qui n'a rien à perdre — sauf toi.\u00a0»",a:"Ilya Rozanov",c:"I"},
  {t:"«\u00a0Je ne t'ai pas choisi. Mais si j'avais pu choisir, ce serait encore toi.\u00a0»",a:"Shane Hollander",c:"S"},
  {t:"«\u00a0On ne peut pas être amis. On ne peut pas être ennemis. Alors qu'est-ce qu'on est ?\u00a0»",a:"Shane Hollander",c:"S"},
  {t:"«\u00a0Dix ans à jouer la comédie. Et la seule chose réelle, c'était toi.\u00a0»",a:"Ilya Rozanov",c:"I"},
  {t:"«\u00a0Je t'en veux d'être aussi impossible à oublier.\u00a0»",a:"Shane Hollander",c:"S"},
  {t:"«\u00a0Tu joues mieux quand tu es en colère contre moi. Alors je continuerai.\u00a0»",a:"Ilya Rozanov",c:"I"},
  {t:"«\u00a0Le problème avec toi, c'est que tu es partout — même quand tu n'es pas là.\u00a0»",a:"Shane Hollander",c:"S"},
  {t:"«\u00a0Personne ne me regarde comme ça. Même les gens qui m'aiment.\u00a0»",a:"Ilya Rozanov",c:"I"},
  {t:"«\u00a0Je pensais qu'on était rivaux. Je ne savais pas qu'on était destinés.\u00a0»",a:"Shane Hollander",c:"S"},
  {t:"«\u00a0Sur cette glace, je suis ton adversaire. Dans ma tête, tu es mon seul public.\u00a0»",a:"Ilya Rozanov",c:"I"},
  {t:"«\u00a0C'est épuisant de te haïr. Ça l'est encore plus de ne pas pouvoir m'en empêcher.\u00a0»",a:"Shane Hollander",c:"S"},
  {t:"«\u00a0On a passé des années à se blesser. Et maintenant je ne sais plus faire autrement avec toi.\u00a0»",a:"Ilya Rozanov",c:"I"},
  {t:"«\u00a0Tu es la seule personne qui me regarde comme si j'étais à la fois le problème et la solution.\u00a0»",a:"Shane Hollander",c:"S"},
  {t:"«\u00a0J'aurais dû m'en douter. La seule chose plus dangereuse que toi sur la glace, c'est toi dans ma tête.\u00a0»",a:"Ilya Rozanov",c:"I"},
  {t:"«\u00a0Je ne suis pas en train de tomber amoureux de toi. Je suis en train de réaliser que je l'étais depuis longtemps.\u00a0»",a:"Shane Hollander",c:"S"},
  {t:"«\u00a0On s'est battus pendant dix ans. Je suppose qu'on peut apprendre à faire autre chose.\u00a0»",a:"Ilya Rozanov",c:"I"},
  {t:"«\u00a0Il y a des gens qui entrent dans ta vie et qui changent la forme de tout ce qui vient après.\u00a0»",a:"— Rivalité Brûlante",c:"B"},
  {t:"«\u00a0Tu sais ce qui est drôle ? Même quand je gagne contre toi, j'ai l'impression de perdre quelque chose.\u00a0»",a:"Shane Hollander",c:"S"},
  {t:"«\u00a0J'ai appris à jouer contre toi. Je n'ai jamais appris à vivre sans cette tension.\u00a0»",a:"Ilya Rozanov",c:"I"},
  {t:"«\u00a0Les gens pensent qu'on se déteste. Ils ont tort. On se comprend trop bien pour se détester vraiment.\u00a0»",a:"Shane Hollander",c:"S"},
  {t:"«\u00a0On dit que les opposés s'attirent. On dit aussi qu'ils se détruisent. Peut-être les deux.\u00a0»",a:"— Rivalité Brûlante",c:"B"},
  {t:"«\u00a0La première fois que tu m'as regardé comme ça, j'ai su que rien ne serait plus simple.\u00a0»",a:"Ilya Rozanov",c:"I"},
  {t:"«\u00a0Je joue mieux quand tu es là. C'est le problème.\u00a0»",a:"Shane Hollander",c:"S"},
  {t:"«\u00a0On aurait pu être amis si on s'était rencontrés autrement. Mais je suis content qu'on ne l'ait pas fait.\u00a0»",a:"Ilya Rozanov",c:"I"},
  {t:"«\u00a0Quelqu'un qui te pousse à être meilleur, même en étant ton adversaire, c'est rare.\u00a0»",a:"— Rivalité Brûlante",c:"B"},
  {t:"«\u00a0Je n'ai pas besoin que tu m'aimes. J'ai besoin que tu sois là.\u00a0»",a:"Shane Hollander",c:"S"},
  {t:"«\u00a0La glace ne ment pas. Et toi non plus, quand tu crois que personne ne regarde.\u00a0»",a:"Ilya Rozanov",c:"I"},
  {t:"«\u00a0On a passé des années à faire semblant que c'était de la haine. C'était plus facile.\u00a0»",a:"Shane Hollander",c:"S"},
  {t:"«\u00a0Tu es la seule rivale que j'aie jamais voulu garder près de moi.\u00a0»",a:"Ilya Rozanov",c:"I"},
  {t:"«\u00a0Même nos silences sont une conversation.\u00a0»",a:"— Rivalité Brûlante",c:"B"},
  {t:"«\u00a0On se ressemble trop pour être amis. Pas assez pour être ennemis.\u00a0»",a:"Shane Hollander",c:"S"},
