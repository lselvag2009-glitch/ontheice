.toggle-row{display:flex;align-items:center;gap:14px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:14px;padding:14px;margin-bottom:12px;cursor:pointer;}
.toggle{width:44px;height:24px;border-radius:12px;position:relative;transition:background 0.3s;flex-shrink:0;}
