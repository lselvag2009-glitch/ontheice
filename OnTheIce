  zone.innerHTML=`
    <div class="stitle"><div class="bar" style="background:${c};"></div><span style="color:${c};">Résultats — "${cineSearchQuery}"</span></div>
    ${cineSearchResults.length===0?`<div style="color:var(--sub);font-size:13px;text-align:center;padding:20px;">Aucun résultat</div>`:""}
    ${cineSearchResults.map(m=>cineCard(m)).join("")}
  `;
}

async function doSearch(){
  cineSearchLoading=true; renderCineSearchZone();
  try{
    const type=state.cineTab==="series"?"tv":"movie";
    const d=await tmdbFetch(`/search/${type}?query=${encodeURIComponent(cineSearchQuery)}&page=1`);
    cineSearchResults=(d.results||[]).slice(0,10).map(m=>formatItem(m,type));
  }catch(e){ cineSearchResults=[]; }
  cineSearchLoading=false; renderCineSearchZone();
}

function formatItem(m,type){
  return {
    id: m.id,
    type: type||"movie",
    title: m.title||m.name||"",
    date: m.release_date||m.first_air_date||"",
    score: m.vote_average?m.vote_average.toFixed(1):"N/A",
    poster: m.poster_path?TMDB_IMG_SM+m.poster_path:null,
    poster_lg: m.poster_path?TMDB_IMG_LG+m.poster_path:null,
    synopsis: m.overview?(m.overview.slice(0,150)+(m.overview.length>150?"...":"")):""
  };
}

