function getProviders(watchData){
  const fr = watchData?.results?.FR;
  const flat = fr?.flatrate||[];
  const rent = fr?.rent||[];
  const all = [...flat, ...rent.filter(r=>!flat.find(f=>f.provider_id===r.provider_id))];
  return all.slice(0,5).map(p=>({
    id: p.provider_id,
    name: PROVIDERS[p.provider_id]?.name || p.provider_name,
    color: PROVIDERS[p.provider_id]?.color || "#888",
    icon: PROVIDERS[p.provider_id]?.icon || p.provider_name.slice(0,2),
    logo: p.logo_path ? `https://image.tmdb.org/t/p/w45${p.logo_path}` : null,
