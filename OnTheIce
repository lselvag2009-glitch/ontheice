// ── ACTIONS ───────────────────────────────────────────────────────────────────
function selDay(ds){state.selDay=ds;state.journalDraft=state.journal[ds]?.text||"";state.journalTitle=state.journal[ds]?.title||"";state.journalMood=state.journal[ds]?.mood||null;state.journalEmoji=state.journal[ds]?.emoji||"";state.journalTags=state.journal[ds]?.tags||[];state.journalPhoto=state.journal[ds]?.photo||null;render();}
function showSection(v){state.view=v;render();}
function nextQuote(){state.quoteIdx=(state.quoteIdx+1)%QUOTES.length;vib([5]);render();}
function toggleFav(i){state.favs=state.favs.includes(i)?state.favs.filter(x=>x!==i):[...state.favs,i];save();render();}
function togglePom(){state.pom.running=!state.pom.running;if(state.pom.running)playSound("check");render();}
function resetPom(){state.pom.running=false;state.pom.mode="work";state.pom.secs=25*60;if(window._pt){clearInterval(window._pt);window._pt=null;}render();}
function setPomDur(v,m){state.pom.running=false;state.pom.mode=m;state.pom.secs=v;if(window._pt){clearInterval(window._pt);window._pt=null;}render();}
function toggleHabit(hid){vib([8]);playSound("check");if(!state.checked[todayStr])state.checked[todayStr]={};state.checked[todayStr][hid]=!state.checked[todayStr][hid];if(state.habits.filter(h=>state.checked[todayStr][h.id]).length===state.habits.length)setTimeout(()=>{playSound("done");vib([100,50,100]);},100);save();render();}
function addHabit(){const nh=state.newHabit;if(!nh.label.trim())return;state.habits.push({id:Date.now().toString(),...nh});vib([10,5,10]);state.newHabit={label:"",icon:"⭐",color:"#4ECDC4"};state.showHabitForm=false;save();render();}
function saveJournal(){if(!state.journalDraft.trim()&&!state.journalMood)return;state.journal[state.selDay]={text:state.journalDraft,mood:state.journalMood,date:state.selDay};vib([10,5,10]);playSound("done");toast("💾 Journal sauvegardé","","var(--accent)");save();render();}
function setTheme(k){state.theme=k;applyTheme(k);save();render();}
function toggleSound(){state.sound=!state.sound;save();render();}

// ── INIT ──────────────────────────────────────────────────────────────────────
applyTheme(state.theme);
setTimeout(()=>{const s=document.getElementById("splash");if(s)s.style.display="none";},2800);

// Démarre directement sur l'accueil — toujours
document.getElementById("nav").style.display="flex";
applyTheme(state.theme);
render();
</script>
