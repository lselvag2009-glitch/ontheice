  }));
}

const COUNTRY_NAMES = {
  FR:"🇫🇷 France",US:"🇺🇸 États-Unis",GB:"🇬🇧 Royaume-Uni",CA:"🇨🇦 Canada",
  AU:"🇦🇺 Australie",DE:"🇩🇪 Allemagne",JP:"🇯🇵 Japon",IT:"🇮🇹 Italie",
  ES:"🇪🇸 Espagne",BE:"🇧🇪 Belgique",CH:"🇨🇭 Suisse",NL:"🇳🇱 Pays-Bas",
  BR:"🇧🇷 Brésil",MX:"🇲🇽 Mexique",NC:"🇳🇨 Nouvelle-Calédonie",
  PT:"🇵🇹 Portugal",PL:"🇵🇱 Pologne",SE:"🇸🇪 Suède",NO:"🇳🇴 Norvège",
  DK:"🇩🇰 Danemark",FI:"🇫🇮 Finlande",AR:"🇦🇷 Argentine",
  IN:"🇮🇳 Inde",KR:"🇰🇷 Corée du Sud",ZA:"🇿🇦 Afrique du Sud",
};

function getCountries(watchData){
  const results = watchData?.results || {};
  return Object.entries(results)
    .filter(([code, data]) => data.flatrate && data.flatrate.length > 0)
    .map(([code]) => COUNTRY_NAMES[code] || `🌐 ${code}`)
    .sort((a,b) => {
      // France en premier
      if(a.includes("France")) return -1;
      if(b.includes("France")) return 1;
      return a.localeCompare(b);
    });
}

async function openDetail(id, type){
  try{
    const [detail, credits, similar, watchData] = await Promise.all([
      tmdbFetch(`/${type}/${id}`),
      tmdbFetch(`/${type}/${id}/credits`),
      tmdbFetch(`/${type}/${id}/similar?page=1`),
      tmdbFetch(`/${type}/${id}/watch/providers`)
    ]);
    const cast=(credits.cast||[]).slice(0,8).map(a=>({
      id:a.id, name:a.name, char:a.character,
      photo:a.profile_path?TMDB_IMG_SM+a.profile_path:null
    }));
    state.detailItem={
      id, type,
      title: detail.title||detail.name,
      tagline: detail.tagline||"",
      date: detail.release_date||detail.first_air_date||"",
      score: detail.vote_average?detail.vote_average.toFixed(1):"N/A",
      votes: detail.vote_count||0,
      poster: detail.poster_path?TMDB_IMG_LG+detail.poster_path:null,
      synopsis: detail.overview||"",
      genres: (detail.genres||[]).map(g=>g.name),
      runtime: detail.runtime||(detail.episode_run_time?detail.episode_run_time[0]:null),
      seasons: detail.number_of_seasons||null,
      episodes: detail.number_of_episodes||null,
      status: detail.status||"",
      providers: getProviders(watchData),
      countries: getCountries(watchData),
      cast,
      similar: (similar.results||[]).slice(0,6).map(m=>formatItem(m,type))
    };
    showSection("detail");
  }catch(e){ toast("❌","Impossible de charger","#C8102E"); }
}

// Cache pour éviter JSON dans les onclick
const ITEM_CACHE = {};
function cacheItem(item){ const k=`${item.type}_${item.id}`; ITEM_CACHE[k]=item; return k; }
function addToListById(k,lt){ if(ITEM_CACHE[k]) addToList(ITEM_CACHE[k],lt); }

function addToList(item, listType){
  const key = listType==="watched"?"cineWatched":"cineMyList";
  const lsKey = listType==="watched"?"oti_cinewatched":"oti_cinelist";
  if(!state[key].find(x=>x.id===item.id&&x.type===item.type)){
    state[key].push(item);
    LS.set(lsKey, state[key]);
    vib([10,5,10]); playSound("done");
    toast(listType==="watched"?"✅ Ajouté à Déjà vu":"📋 Ajouté à À voir","","#1DB954");
    render();
  } else {
    toast("⚠️","Déjà dans la liste","#FFD700");
  }
}

function removeFromList(id, type, listType){
  const key = listType==="watched"?"cineWatched":"cineMyList";
  const lsKey = listType==="watched"?"oti_cinewatched":"oti_cinelist";
  state[key]=state[key].filter(x=>!(x.id===id&&x.type===type));
  LS.set(lsKey, state[key]); vib([20]); render();
}

function setRating(id, type, stars){
  state.cineRatings[`${type}_${id}`]=stars;
  LS.set("oti_cineratings", state.cineRatings); render();
}

function getRating(id, type){ return state.cineRatings[`${type}_${id}`]||0; }

function inList(id, type, listType){
  const key = listType==="watched"?"cineWatched":"cineMyList";
  return !!(state[key]||[]).find(x=>x.id===id&&x.type===type);
}

