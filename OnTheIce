const TMDB_KEY = "41014af0f559f6541f2da4cd1c5acc1a";
const TMDB_BASE = "https://api.themoviedb.org/3";
const TMDB_IMG_SM = "https://image.tmdb.org/t/p/w200";
const TMDB_IMG_LG = "https://image.tmdb.org/t/p/w500";

const CINE_CACHE = {};
const CINE_LOADING = {};
let cineSearchQuery = "";
let cineSearchResults = null;
let cineSearchLoading = false;
let _cineSearchTimer = null;

async function tmdbFetch(path){
  const sep = path.includes("?")?"&":"?";
  const url = `${TMDB_BASE}${path}${sep}api_key=${TMDB_KEY}&language=fr-FR`;
  const res = await fetch(url);
  if(!res.ok) throw new Error(`TMDB ${res.status}`);
  return res.json();
}

function loadPopular(key,path){if(!CINE_CACHE[key]&&!CINE_LOADING[key])loadCineSection(key,path);}
function resetCineCache(){Object.keys(CINE_CACHE).forEach(k=>delete CINE_CACHE[k]);render();}
async function loadCineSection(key, path){
  if(CINE_CACHE[key]||CINE_LOADING[key]) return;
  CINE_LOADING[key]=true; render();
  try{ CINE_CACHE[key]=await tmdbFetch(path); }
  catch(e){ CINE_CACHE[key]={error:true,msg:e.message}; }
  CINE_LOADING[key]=false; render();
}

function onCineSearch(val){
  cineSearchQuery=val;
  clearTimeout(_cineSearchTimer);
  if(!val.trim()){ cineSearchResults=null; renderCineSearchZone(); return; }
  _cineSearchTimer=setTimeout(doSearch,500);
}

function renderCineSearchZone(){
  // Mise à jour partielle — seulement la zone résultats, sans toucher l'input
  const zone=document.getElementById("cine-search-results");
  if(!zone){ render(); return; }
